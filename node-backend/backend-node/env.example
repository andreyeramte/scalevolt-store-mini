# ScaleVolt Backend Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these values from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings > Database
# 4. Copy the connection string from "Connection string" section

# Supabase Database URL (Primary connection)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Alternative: Use DATABASE_URL (some platforms prefer this)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Project URL (for API calls)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Supabase Anon Key (for client-side operations)
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# Supabase Service Role Key (for admin operations)
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# =============================================================================
# CLOUDINARY CONFIGURATION
# =============================================================================
# Get these values from your Cloudinary dashboard:
# 1. Go to https://cloudinary.com/console
# 2. Copy your Cloud Name, API Key, and API Secret

CLOUDINARY_CLOUD_NAME=ds6mvmvba
CLOUDINARY_API_KEY=692525747653515
CLOUDINARY_API_SECRET=[YOUR-API-SECRET]

# =============================================================================
# STRIPE PAYMENT CONFIGURATION
# =============================================================================
# Get these values from your Stripe dashboard:
# 1. Go to https://dashboard.stripe.com/
# 2. Copy your Secret Key and Webhook Secret

STRIPE_SECRET_KEY=[YOUR-STRIPE-SECRET-KEY]
STRIPE_WEBHOOK_SECRET=[YOUR-STRIPE-WEBHOOK-SECRET]
STRIPE_PUBLISHABLE_KEY=[YOUR-STRIPE-PUBLISHABLE-KEY]

# =============================================================================
# RESEND EMAIL CONFIGURATION
# =============================================================================
# Get this from Resend.com:
# 1. Go to https://resend.com/
# 2. Create account and get API key

RESEND_API_KEY=[YOUR-RESEND-API-KEY]
EMAIL_FROM=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# =============================================================================
# SHEETDB CONFIGURATION
# =============================================================================
# Get this from SheetDB after connecting your Google Sheet:
# 1. Go to https://sheetdb.io/
# 2. Create API for your Google Sheet
# 3. Copy the API URL

SHEETDB_URL=https://sheetdb.io/api/v1/[YOUR-API-KEY]

# =============================================================================
# GOOGLE ANALYTICS 4 CONFIGURATION
# =============================================================================
# Get these from Google Analytics:
# 1. Go to https://analytics.google.com/
# 2. Create property and get Measurement ID and API Secret

GA4_MEASUREMENT_ID=[YOUR-GA4-MEASUREMENT-ID]
GA4_API_SECRET=[YOUR-GA4-API-SECRET]
ENABLE_ANALYTICS=true

# =============================================================================
# SENTRY ERROR MONITORING
# =============================================================================
# Get this from Sentry.io:
# 1. Go to https://sentry.io/
# 2. Create project and get DSN

SENTRY_DSN=[YOUR-SENTRY-DSN]
ENABLE_SENTRY=true

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Server ports
PORT=4242
ADMIN_PORT=4243

# Environment
NODE_ENV=development

# Frontend URL (for CORS and redirects)
FRONTEND_URL=https://yourdomain.com

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT secret for authentication
JWT_SECRET=[YOUR-JWT-SECRET-KEY]

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Directory for file uploads
UPLOAD_DIR=./uploads

# =============================================================================
# AUTOMATION & CRON JOBS
# =============================================================================
# Enable automated tasks
ENABLE_CRON=true

# =============================================================================
# DOMAIN & EXTERNAL SERVICES
# =============================================================================
# Your domain
DOMAIN=https://yourdomain.com

# Google Translate API
GOOGLE_TRANSLATE_API_KEY=[YOUR-GOOGLE-TRANSLATE-API-KEY]

# =============================================================================
# DATABASE CONNECTION (Alternative - if not using Supabase)
# =============================================================================
# PostgreSQL connection details
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=[YOUR-PASSWORD]
PGDATABASE=scalevolt_store

# Alternative database connection
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=[YOUR-PASSWORD]
DB_NAME=scalevolt_store

