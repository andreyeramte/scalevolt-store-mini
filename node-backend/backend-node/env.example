# ScaleVolt Backend Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these values from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings > Database
# 4. Copy the connection string from "Connection string" section

# Supabase Database URL (Primary connection)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Alternative: Use DATABASE_URL (some platforms prefer this)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Project URL (for API calls)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Supabase Anon Key (for client-side operations)
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# Supabase Service Role Key (for admin operations)
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# =============================================================================
# SHEETDB CONFIGURATION (for Google Sheets sync)
# =============================================================================
# Get this from SheetDB.io after connecting your Google Sheet:
# 1. Go to https://sheetdb.io/
# 2. Connect your Google Sheet
# 3. Copy the API endpoint URL

# SheetDB API URL for Google Sheets sync
SHEETDB_URL=https://sheetdb.io/api/v1/[YOUR-SHEETDB-API-KEY]

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=4242
ADMIN_PORT=3001
NODE_ENV=development

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT secret for API authentication
JWT_SECRET=your-jwt-secret-key-here

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5179,http://localhost:5178,http://localhost:5177,http://localhost:3000,http://localhost:4242

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_DIR=./uploads

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
# Firebase Configuration (for frontend auth)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=your-app-id

# Intercom (optional)
INTERCOM_APP_ID=your-intercom-app-id

# Google Analytics (optional)
GA_TRACKING_ID=your-ga-tracking-id

# =============================================================================
# HOW TO GET SUPABASE VALUES:
# =============================================================================
# 1. Go to https://supabase.com/dashboard
# 2. Create a new project or select existing one
# 3. Go to Settings > Database
# 4. Copy the connection string from "Connection string" section
# 5. Go to Settings > API to get your API keys
# 6. Replace [YOUR-PROJECT-REF] with your actual project reference
# 7. Replace [YOUR-PASSWORD] with your database password

# =============================================================================
# HOW TO GET SHEETDB VALUES:
# =============================================================================
# 1. Go to https://sheetdb.io/
# 2. Sign up and create a new API
# 3. Connect your Google Sheet (make sure it's public or shared)
# 4. Copy the API endpoint URL
# 5. Replace [YOUR-SHEETDB-API-KEY] with your actual API key
# 6. Your Google Sheet should have columns like: SKU, Name, Description, Price, etc.

