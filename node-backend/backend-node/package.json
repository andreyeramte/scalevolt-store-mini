{
  "name": "scalevolt-backend",
  "version": "1.0.0",
  "description": "ScaleVolt Store Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "migrate": "psql \"$PGDATABASE\" -f db/migrations/20250718_create_products.sql",
    "import:products": "node importProducts.js",
    "deploy": "npm run migrate && npm run import:products && npm run start"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "fs": "^0.0.1-security",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "path": "^0.12.7",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.2.5"
  },
  "keywords": [
    "express",
    "api",
    "scalevolt",
    "backend"
