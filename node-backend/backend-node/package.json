{
  "name": "scalevolt-backend",
  "version": "1.0.0",
  "description": "ScaleVolt Store Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "psql \"$PGDATABASE\" -f db/schema.sql",
    "import:products": "node scripts/importProducts.js",
    "deploy": "npm run migrate && npm run import:products && npm run start",
    "test:db": "node -e \"const { pool } = require('./db/pool'); pool.query('SELECT 1').then(() => { console.log('✅ Database connection successful'); process.exit(0); }).catch(e => { console.error('❌ Database connection failed:', e.message); process.exit(1); })\"",
    "test:connections": "node scripts/testConnections.js"
  },
  "dependencies": {
    "@sentry/node": "^10.5.0",
    "@supabase/supabase-js": "^2.58.0",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "body-parser": "^1.20.2",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "fs": "^0.0.1-security",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "path": "^0.12.7",
    "pg": "^8.16.3",
    "resend": "^6.0.1",
    "sharp": "^0.34.3",
    "stripe": "^18.4.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.2.5"
  },
  "keywords": [
    "express",
    "api",
    "scalevolt",
    "backend"
  ],
  "author": "",
  "license": "ISC"
}
