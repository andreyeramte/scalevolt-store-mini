# Build stage
FROM node:20-alpine as build
WORKDIR /app
COPY package*.json ./

# Clear npm cache and install dependencies with force flag
RUN npm cache clean --force
RUN npm install --force

COPY . .

# Try to build, if it fails, reinstall and try again
RUN npm run build || (npm cache clean --force && npm install --force && npm run build)

# Production stage
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]