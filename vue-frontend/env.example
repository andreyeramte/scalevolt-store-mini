# ScaleVolt Store Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Backend API URL
VITE_API_URL=http://localhost:4242/api

# Admin Panel URL
VITE_ADMIN_URL=http://localhost:3001/admin

# =============================================================================
# FIREBASE CONFIGURATION (Required for Authentication)
# =============================================================================

# Get these values from your Firebase Console:
# 1. Go to https://console.firebase.google.com/
# 2. Select your project
# 3. Go to Project Settings (gear icon)
# 4. Scroll down to "Your apps" section
# 5. Click on your web app or create a new one
# 6. Copy the config values

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================

# Intercom (for customer support)
VITE_INTERCOM_APP_ID=your_intercom_app_id_here

# Google Analytics
VITE_GA_TRACKING_ID=your_google_analytics_tracking_id_here

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
VITE_ENABLE_CHATBOT=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_INTERCOM=false

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Development mode
VITE_DEV_MODE=true

# Debug mode
VITE_DEBUG=false

# Mock API mode (for development without backend)
VITE_MOCK_API=false

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Production API URL (for deployment)
# VITE_API_URL=https://your-backend-url.com/api

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================

# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. For Firebase setup:
#    - Go to https://console.firebase.google.com/
#    - Create a new project or select existing
#    - Enable Authentication (Email/Password)
#    - Go to Project Settings > General
#    - Scroll to "Your apps" and create a web app
#    - Copy the config values to the VITE_FIREBASE_* variables
# 4. For local development:
#    - Keep VITE_API_URL as http://localhost:4242/api
#    - Set VITE_DEV_MODE=true
# 5. For production deployment:
#    - Update VITE_API_URL to your production backend URL
#    - Set VITE_DEV_MODE=false
